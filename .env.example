# Vercel Blob (obligatorio para guardar los CSV).
# Generar en: https://vercel.com/dashboard -> Storage -> Blob -> Create Token (Read & Write)
BLOB_READ_WRITE_TOKEN=

# Tamaño máximo de PDF en bytes (10 MB por defecto)
MAX_PDF_BYTES=10485760

# Cabecera CSV por defecto (separada por comas, sin espacios)
DEFAULT_HEADER=numero,pregunta,a,b,c,d,correcta,materia
